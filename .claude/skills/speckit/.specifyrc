# Speckit Configuration
# This file configures project-specific settings for the speckit workflow.
# Upstream scripts should read from this file to customize behavior.

# Feature branch naming pattern
# Format: ISSUE_NUMBER-feature-description (zero-padded, auto-incremented)
# Example: 001-user-preferences
#
# Pattern regex: ^[0-9]{3}-
SPECIFY_BRANCH_PATTERN="^[0-9]{3}-"
SPECIFY_BRANCH_EXAMPLE="001-feature-name"

# Spec directory structure
# Features are stored at: specs/<branch-name>/
# Example: specs/001-user-preferences/spec.md
SPECIFY_SPEC_ROOT="specs"
